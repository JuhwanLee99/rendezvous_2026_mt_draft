# Firebase 웹 앱 설정값 (콘솔 > 프로젝트 설정 > 내 앱 > SDK 설정/구성)
# 이 값들은 클라이언트 노출이 안전하다 — 실제 보안은 Firestore 규칙이 강제한다.
# 복사: cp .env.example .env.local  후 값 채우기

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MSG_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 관리자 계정 UID (콘솔 Authentication 에서 관리자 생성 후 복사). 여러 명이면 콤마 구분.
# 같은 UID 를 firestore.rules 의 isAdmin() 목록에도 넣어야 한다.
VITE_ADMIN_UIDS=

# 배포 도메인 (카카오톡/SNS 링크 공유 미리보기용 절대 URL). 끝에 슬래시(/) 없이.
# 예: https://your-project-id.web.app  → og:image 가 .../og-image.png 로 빌드됨.
# 비워두면 공유 미리보기 이미지가 깨지므로 배포 전 반드시 채울 것.
VITE_SITE_URL=
